{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quantum Info Curriculum Map",
  "type": "object",
  "required": [
    "schema_version",
    "project",
    "status_values",
    "levels"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "project": {
      "type": "object",
      "required": [
        "app_repository",
        "app_baseline_commit",
        "manuscript_title",
        "primary_audience",
        "prerequisites"
      ]
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "level",
          "level_id",
          "title_en",
          "status",
          "book_chapters",
          "concepts",
          "misconceptions",
          "experiments",
          "validation"
        ],
        "properties": {
          "level": {
            "type": "integer",
            "minimum": 0
          },
          "level_id": {
            "type": "string",
            "pattern": "^L[0-9]{2}$"
          },
          "status": {
            "enum": [
              "public_main",
              "local_uncommitted",
              "planned"
            ]
          },
          "book_chapters": {
            "type": "array",
            "minItems": 1
          },
          "experiments": {
            "type": "array"
          }
        }
      }
    }
  }
}
